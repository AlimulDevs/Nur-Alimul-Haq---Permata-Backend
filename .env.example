# Application
APP_PORT=3000
NODE_ENV=development

# Swagger — set to 'true' to disable in production
SWAGGER_DISABLED=false

# JWT
JWT_SECRET=change_this_to_a_random_strong_secret_min_32_chars
JWT_EXPIRES_IN=1d

# Database (MSSQL) — raw vars kept for reference / tooling
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=YourStrong!Passw0rd
DB_DATABASE=BookstoreDB

# Prisma connection URL (used by NestJS app and seeder)
# Local dev:  sqlserver://localhost:1433;database=BookstoreDB;user=sa;password=...;trustServerCertificate=true;encrypt=false
# Docker:     sqlserver://mssql:1433;database=BookstoreDB;...  (overridden via docker-compose.yml)
DATABASE_URL="sqlserver://localhost:1433;database=BookstoreDB;user=sa;password=YourStrong!Passw0rd;trustServerCertificate=true;encrypt=false"

# Admin Seed (used by seeder script)
ADMIN_EMAIL=admin@bookstore.com
ADMIN_PASSWORD=Admin@1234
ADMIN_FULL_NAME=Super Admin
